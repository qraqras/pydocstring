#!/usr/bin/env bash
set -euo pipefail

echo "=== Pre-commit: Auto-fix fmt & clippy ==="

echo "--- Format ---"
cargo fmt --all
echo "OK"

echo "--- Clippy check ---"
cargo clippy --all-targets -- -D warnings
echo "OK"

echo "--- Stage fixed files ---"
git diff --cached --name-only --diff-filter=ACMR | xargs -r git add
echo "OK"

echo "=== All checks passed ==="
